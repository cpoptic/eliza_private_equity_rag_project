# LLM
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6

# Embeddings
OPENAI_API_KEY=sk-...
EMBEDDER=openai                          # openai | local
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Vector store
VECTOR_STORE=chroma                      # chroma | qdrant
CHROMA_PATH=./.chroma
CHROMA_COLLECTION=sec_filings
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=sec_filings

# Corpus
CORPUS_DIR=edgar_corpus

# Retrieval tuning
TOP_K_DENSE=20
TOP_K_BM25=20
TOP_K_FINAL=12
